ss","QuestionType":"TE","Selector":"FORM","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is your mailing address?Please enter the address where you'd like to receive drinks shipped...","Choices":{"1":{"Display":"Full name","TextEntryLength":"Medium","TextEntryValidation":"ValidTextOnly","TextEntry":"on"},"2":{"Display":"Street address (Line 1)","TextEntryLength":"Medium","TextEntryValidation":"ForceResponse","TextEntry":"on"},"3":{"Display":"Street address (Line 2)","TextEntryLength":"Medium","TextEntry":"on"},"4":{"Display":"City","TextEntryLength":"Medium","TextEntryValidation":"ValidTextOnly","TextEntry":"on"},"5":{"Display":"State","TextEntryLength":"Short","TextEntryValidation":"ValidUSState","TextEntry":"on"},"6":{"Display":"ZIP","TextEntryLength":"Short","TextEntryValidation":"USZip","TextEntry":"on"}},"ChoiceOrder":["1","2","3","4","5","6"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":null}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID183"}},{"SurveyID":"SV_6fkaYAyCnM3OOge","Element":"SQ","PrimaryAttribute":"QID177","SecondaryAttribute":"What is your mobile phone number?We will use this to send you a text message about taking Part 2...","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your mobile phone number?\n<ul>\n\t<li>We will use this to send you a text message about taking Part 2 of the survey. This is important because our emails about Part 2 sometimes get caught in people's spam filters.<\/li>\n\t<li>We will not share your number with anyone else or use it for any other purpose.&nbsp;<\/li>\n<\/ul>","DefaultChoices":false,"DataExportTag":"phone","QuestionType":"TE","Selector":"SL","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is your mobile phone number?We will use this to send you a text message about taking Part 2...","Validation":{"Settings":{"ForceResponse":"ON","ForceRe