ndaryAttribute":"Which one of these foods is more likely to raise people's blood cholesterol? Please select one.","TertiaryAttribute":null,"Payload":{"QuestionText":"<span id=\"docs-internal-guid-28957440-7fff-ff05-e50c-1c05f08cf04f\"><span style=\"font-size: 11pt; font-family: Arial; color: rgb(0, 0, 0); background-color: transparent; font-variant-numeric: normal; font-variant-east-asian: normal; vertical-align: baseline; white-space: pre-wrap;\">Which one of these foods is more likely to raise people's blood cholesterol? Please select one.<\/span><\/span>","DefaultChoices":false,"DataExportTag":"raise_cholesterol","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Which one of these foods is more likely to raise people's blood cholesterol? Please select one.","Choices":{"1":{"Display":"Eggs"},"2":{"Display":"Vegetable oils"},"3":{"Display":"Animal fat"},"4":{"Display":"Not sure"}},"ChoiceOrder":["1","2","3","4"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID144"}},{"SurveyID":"SV_6fkaYAyCnM3OOge","Element":"OCAC","PrimaryAttribute":"OCAC_13E0WfCahj5KyrV","SecondaryAttribute":"OC_DzcNC6ZFn0Do0cs","TertiaryAttribute":"Email","Payload":{"actionId":"OCAC_13E0WfCahj5KyrV","contextId":"SV_6fkaYAyCnM3OOge","createdAt":1635190349596,"delay":"Custom","delayInHours":72,"delayInput":3,"delayLabel":"days","delayUnits":"days","dependencies":[],"edata":"user","edataLabel":"Survey Flow","elementConfigured":true,"expireLabel":"Expire After","from":{"email":"daniel.m.cohen@berkeley.edu","name":"Online Drink Shopping - Market Research"},"keyvalues":[{"key":"EMAIL","value":"daniel.m.cohen@berkeley.edu"},{"key":"NAME","value":"Online Drink Shopping - Market Research"}],"message":"<p dir=\"ltr\">Dear&nbsp;${q:\/\/QID172\/ChoiceTextEntryValue},<br \/>\n<br \/>\nThank you for completing Part 1 of our research study on drink purchasing patterns. Please click the following link to take Part 2!<br \/>\n<br \/>\n<a href=\"https:\/\/berkeley.qualtrics.com\/jfe\/form\/SV_9Xle3s32xKQvH2C\">Survey Part 2<\/a><\/p>\n\n<ul dir=\"ltr\">\n\t<li>If at all possible, please take the survey today, or tomorrow at the latest. It should take about ten minutes.&nbsp;<\/li>\n\t<li>You must take this survey on a tablet, laptop, or desktop computer, not on a mobile phone.&nbsp;<\/li>\n\t<li>After you complete Part 2, we will pay you $15 using an online gift card and possibly a 12-pack of drinks that you choose in one of the survey questions.&nbsp;<\/li>\n<\/ul>\nThanks again! If you have any questions or concerns about this study, you may contact Daniel Cohen at daniel.m.cohen@berkeley.edu.","outcomeId":"OC_DzcNC6ZFn0Do0cs","ownerObject":{"orgId":"berkeley","userId":"UR_3gjqY7lX9vFHopv"},"replyTo":{"email":"daniel.m.cohen@berkeley.edu"},"replyToEmail":"daniel.m.cohen@berkeley.edu","responseSummaryLanguage":"Response Language","responseSummaryLanguageCode":"default","srsTTL":7,"srsTTLUnits":"days","srsTTLUnitsLabel":"days","srsWillExpire":true,"subject":"Part 2 of drink purchasing survey","surveyId":"SV_6fkaYAyCnM3OOge","taskNumber":1,"taskRegistryId":"Email","to":[{"email":"${e:\/\/Field\/ContactEmail}"}],"translatedLink":"link","translatedLinkMessage":"Please follow the link to view the response summary:","translatedToAddresses":"${e:\/\/Field\/ContactEmail}","triggerAction":"Email","whenLabel":"Send After..."}},{"SurveyID":"SV_6fkaYAyCnM3OOge","Element":"OCAC","PrimaryAttribute":"OCAC_FHO3KqlmlU0gGHU","SecondaryAttribute":"OC_E39CLWgYlo3Fz3H","TertiaryAttribute":"Email","Payload":{"actionId":"OCAC_FHO3KqlmlU0gGHU","contextId":"SV_6fkaYAyCnM3OOge","createdAt":1635190317895,"delay":"Custom","delayInHours":120,"delayInput":5,"delayLabel":"days","delayUnits":"days","dependencies":[],"edata":"user","edataLabel":"Survey Flow","elementConfigured":true,"expireLabel":"Expire After","from":{"email":"daniel.m.cohen@berkeley.edu","name":"Online Drink Shopping - Market Research"},"keyvalues":[{"key":"EMAIL","value":"daniel.m.cohen@berkeley.edu"},{"key":"NAME","value":"Online Drink Shopping - Market Research"}],"message":"<p dir=\"ltr\"><em>If you already completed Part 2 of the survey, please disregard this email.<\/em><br \/>\n<br \/>\nDear&nbsp;${q:\/\/QID172\/ChoiceTextEntryValue},<br \/>\n<br \/>\nThank you for completing Part 1 of our research study on drink purchasing patterns. Please click the following link to take Part 2!<br \/>\n<br \/>\n<a href=\"https:\/\/berkeley.qualtrics.com\/jfe\/form\/SV_9Xle3s32xKQvH2C\">Survey Part 2<\/a><\/p>\n\n<ul dir=\"ltr\">\n\t<li>If at all possible, please take the survey today, or tomorrow at the latest. It should take about ten minutes.&nbsp;<\/li>\n\t<li>You must take this survey on a tablet, laptop, or desktop computer, not on a mobile phone.&nbsp;<\/li>\n\t<li>After you complete Part 2, we will pay you $15 using an online gift card and possibly a 12-pack of drinks that you choose in one of the survey questions.&nbsp;<\/li>\n<\/ul>\nThanks again! If you have any questions or concerns about this study, you may contact Daniel Cohen at daniel.m.cohen@berkeley.edu.","outcomeId":"OC_E39CLWgYlo3Fz3H","ownerObject":{"orgId":"berkeley","userId":"UR_3gjqY7lX9vFHopv"},"replyTo":{"email":"daniel.m.cohen@berkeley.edu"},"replyToEmail":"daniel.m.cohen@berkeley.edu","responseSummaryLanguage":"Response Language","responseSummaryLanguageCode":"default","srsTTL":7,"srsTTLUnits":"days","srsTTLUnitsLabel":"days","srsWillExpire":true,"subject":"Last chance! Take Part 2 of drink purchasing survey","surveyId":"SV_6fkaYAyCnM3OOge","taskNumber":1,"taskRegistryId":"Email","to":[{"email":"${e:\/\/Field\/ContactEmail}"}],"translatedLink":"link","translatedLinkMessage":"Please follow the link to view the response summary:","translatedToAddresses":"${e:\/\/Field\/ContactEmail}","triggerAction":"Email","whenLabel":"Send 