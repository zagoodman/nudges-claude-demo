0.5;\n\tvar n = num.toFixed(2);\n\tmultistring = multistring + \"\\<tr class='middletd'> \" + \n\t\"<td style='width:10em;border-top: 1px solid black;border-bottom: 1px solid black' class='letters' id='\" + (i+1) + \"left' name='\" + (i+1) + \"'>\" +\n\t\"Labels\" + \"<\/td>\" +\n\t\"<td style='width:10em'>OR<\/td>\" +\n\t\"<td style='width:10em;border-top: 1px solid black;border-bottom: 1px solid black'  class='letters' id='\" + (i+1) + \"right' name='\" + (i+1) + \"'> \" +\n\t\"No labels + earn \" + optionBunits + display_array[11-i] + \"<\/td> <\/tr>\";\n}\n\/\/ ============================================================================\n\/\/ SAVE OUTPUT \n\n$j('#maintable').append(multistring)\n\t\t\t\n\nvar choiceThatCounts = -1;\n\/\/save the data\n    var time_start = Date.now() \/ 1000;\n    var times = [];\n    var choices = [];\n    var changed=[];\n\/\/ Up the list count\n\tvar list = \"${e:\/\/Field\/list}\"\n\tvar list =\tparseInt(list);\n\tvar list = list + 1;\n\tQualtrics.SurveyEngine.setEmbeddedData(\"list\", list);\n\t\n\/\/ set var = -1 \nvar choice_now = -1 ; \n\n$j('.letters').click(function() {\n\tid = $j(this).attr('name');\n\tvar time = Date.now() \/ 1000 - time_start;      \n    choice_now = $j(this).attr('id');\n    times.push(time.toFixed(2));\n    choices.push(choice_now);\n       \t\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"Time_coke_hyp\", times);\n      \t\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"Choices_coke_hyp\", choices);\n\t\n\tvar id_number = parseInt(id, 10);\n\t$j(\"td[name='\"+id+\"']\").removeClass(\"letters_selected\").addClass(\"letters\");\n\t$j(this ).removeClass(\"letters\").addClass(\"letters_selected\");\t\n            Qualtrics.SurveyEngine.setEmbeddedData(prefix+\"IdFinal_coke_hyp\", id_number);\n\t\t\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"ChoiceFinal_coke_hyp\", choice_now);\n\tif (choice_now.indexOf(\"left\") >= 0) { \n\t\t\t\tvar norm_lb = (id_number-1)*increment;\n\t\t\t\tvar norm_ub = (i