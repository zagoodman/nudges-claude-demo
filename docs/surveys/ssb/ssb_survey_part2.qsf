+ \"left\";\n\t\t\ty = \"#\" + String(k) + \"right\";\n\t\t\t$j( x ).removeClass(\"letters\").addClass(\"letters_selected\");\n\t\t\t$j( y ).addClass(\"letters\").removeClass(\"letters_selected\");\n\t\t}\n\t\tfor (k = id_number +1; k < 101; k++) {\n\t\t\tx = \"#\" + String(k) + \"right\";\n\t\t\ty = \"#\" + String(k) + \"left\";\n\t\t\t$j(x).prop(\"checked\", true);\n\t\t\t$j( x ).removeClass(\"letters\").addClass(\"letters_selected\");\n\t\t\t$j( y ).addClass(\"letters\").removeClass(\"letters_selected\");\n\t\t}\n});\n\n$j('table.uncertainty').floatThead({\n\tuseAbsolutePositioning: false\n\t\/\/ absolutePositioning is better for\n\t\/\/ highly dynamic sites\n\t\/\/ (which this is not)\n});\n\n\t\/\/ enable submit button when variable no longer -1 \n\t this.questionclick = function(event,element)\n    { \t\t \n\tif (choice_now != -1 ) {this.enableNextButton(); }\n     else   { this.disableNextButton();  }\n\t}\n\t\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Imagine the computer selects you to receive the 12 pack of Sprite. We'd like to know how you woul...","DisplayLogic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID829\/SelectableChoice\/5","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">\n\n&amp;nbsp;\nImagine that drink manufacturers could print the above label on some drink containers. Also imagine that the computer selects you to receive the 12 pack of Sprite. Would you prefer to rece...<\/span> <span class=\"LeftOpDesc\">Without the label<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID829\/SelectableChoice\/5","LogicType":"Question","Operator":"Selected","QuestionID":"QID829","QuestionIDFromLocator":"QID829","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"text-align: left;\"><span style=\"white-space: pre-wrap; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: rgb(0, 0, 0);\">We&#39;d like to know how you would (hypothetically) trade off additional payments from this study vs. receiving drink containers with the label.<br \/>\nPlease choose the option you prefer in <\/span><strong style=\"white-space: pre-wrap; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: rgb(0, 0, 0);\">each row<\/strong><span style=\"white-space: pre-wrap; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: rgb(0, 0, 0);\">:<\/span><\/div>","DataExportTag":"sprite_hyp_w_no","QuestionID":"QID833"}},{"SurveyID":"SV_9Xle3s32xKQvH2C","Element":"SQ","PrimaryAttribute":"QID383","SecondaryAttribute":"In the next few screens, we'll show you pairs of drinks with similar flavors. We'd like to learn...","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:16px;\"><span style=\"font-family:Arial,Helvetica,sans-serif;\">In the next few screens, we&#39;ll show you pairs of drinks with similar flavors. We&#39;d like to learn how you would choose between these drinks at different prices.<br \/>\n<br \/>\nHere&#39;s how it works. The table below has 13 rows. In&nbsp;<strong>each row<\/strong>, we&#39;d like you to select whether you prefer one of the three drinks you previously selected as your favorites versus an alternative drink. Suppose, for example, that you chose the Minute Maid Lemonade as one of your three drinks and you are shown the Coca-Cola as the alternative drink.&nbsp;<\/span><\/span>\n<ul>\n\t<li><span style=\"font-size:16px;\"><span style=\"font-family:Arial,Helvetica,sans-serif;\">The Minute Maid Lemonade costs a different amount in each row, ranging from $1 to $7.<\/span><\/span><\/li>\n\t<li><span style=\"font-size:16px;\"><span style=\"font-family:Arial,Helvetica,sans-serif;\">The Coca-Cola&nbsp;costs the same in each row: $4.<\/span><\/span><\/li>\n<\/ul>\n<span style=\"font-size:16px;\"><span style=\"font-family:Arial,Helvetica,sans-serif;\">The price of the Minute Maid Lemonade is relatively low at the top and relatively high at the bottom. Thus, many (although not all) people will choose the Minute Maid Lemonade at the top and the Coca-Cola at the bottom. The main thing to decide is where you want to switch from the Minute Maid Lemonade to the Coca-Cola.<br \/>\n<br \/>\nTo help you answer quickly, we programmed the computer to select on the left for all rows above where you click, and on the right for all rows below. So you just need to decide where you want to switch from left to right, and click there. You can click as many times as you want; then click &ldquo;Next&rdquo; when you are happy with your final choices.<br \/>\n<br \/>\nPlease make your choices in the table below. This one is just for practice.<\/span><\/span>","DefaultChoices":false,"DataExportTag":"mpl_practice_intro","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In the next few screens, we'll show you pairs of drinks with similar flavors. We'd like to learn...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID383","DataVisibility":{"Private":false,"Hidden":false},"QuestionJS":false}},{"SurveyID":"SV_9Xle3s32xKQvH2C","Element":"SQ","PrimaryAttribute":"QID384","SecondaryAttribute":"In these final few screens, we'll again show you pairs of drinks with similar flavors.","TertiaryAttribute":null,"Payload":{"QuestionText":"In these final few screens, we'll again show you pairs of drinks with similar flavors.","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In these final few screens, we'll again show you pairs of drinks with similar flavors.","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"In the next few screens, we'll show you pairs of drinks with similar flavors. We'd like to learn how you would choose between these drinks at different prices.","DataExportTag":"post_intro_screen_c","QuestionID":"QID384","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_9Xle3s32xKQvH2C","Element":"SQ","PrimaryAttribute":"QID386","SecondaryAttribute":"In these final few screens, we'll again show you pairs of drinks with similar flavors. Now, we wi...","TertiaryAttribute":null,"Payload":{"QuestionText":"In these final few screens, we&#39;ll again show you pairs of drinks with similar flavors. Now, we will add nutritional warning labels to drinks with added sugar. Drinks without added sugar will not have warning labels.&nbsp;Below is an example of what this label will look like.<br \/>\n&nbsp;\n<div><img height=\"300\" src=\"https:\/\/berkeley.qualtrics.com\/CP\/Graphic.php?IM=IM_d4LwKfERHcXrUQ6\" style=\"width: 300px; height: 300px;\" width=\"300\" \/><\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In these final few screens, we'll again show you pairs of drinks with similar flavors. Now, we wi...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"In these final few screens, we'll again show you pairs of drinks with similar flavors. Now, we'll add nutrition facts to each drink.","DataVisibility":{"Private":false,"Hidden":false},"DataExportTag":"post_intro_screen_w","QuestionID":"QID386"}},{"SurveyID":"SV_9Xle3s32xKQvH2C","Element":"SQ","PrimaryAttribute":"QID945","SecondaryAttribute":"In these final few screens, we'll again show you pairs of drinks with similar flavors. Now, we wi