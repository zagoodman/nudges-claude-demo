ake) { \n\t\tvar norm_ub = stake;\n\t\tvar changed_now =6 ;\n\t\tchanged.push(changed_now);\n\t};\n\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"LB\", norm_lb);\n\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"UB\", norm_ub);\t\t\t\n\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"Changed\", changed);\t\t\t\n\t\tfor (k = id_number -1; k > 0; k--) {\t\n\t\t\tx = \"#\" + String(k) + \"left\";\n\t\t\ty = \"#\" + String(k) + \"right\";\n\t\t\t$j( x ).removeClass(\"letters\").addClass(\"letters_selected\");\n\t\t\t$j( y ).addClass(\"letters\").removeClass(\"letters_selected\");\n\t\t}\n\t\tfor (k = id_number +1; k < 101; k++) {\n\t\t\tx = \"#\" + String(k) + \"right\";\n\t\t\ty = \"#\" + String(k) + \"left\";\n\t\t\t$j(x).prop(\"checked\", true);\n\t\t\t$j( x ).removeClass(\"letters\").addClass(\"letters_selected\");\n\t\t\t$j( y ).addClass(\"letters\").removeClass(\"letters_selected\");\n\t\t}\n});\n\n$j('table.uncertainty').floatThead({\n\tuseAbsolutePositioning: false\n\t\/\/ absolutePositioning is better for\n\t\/\/ highly dynamic sites\n\t\/\/ (which this is not)\n});\n\n\t\/\/ enable submit button when variable no longer -1 \n\t this.questionclick = function(event,element)\n    { \t\t \n\tif (choice_now != -1 ) {this.enableNextButton(); }\n     else   { this.disableNextButton();  }\n\t}\n\t\n});","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"<div style=\"text-align: left;\"><span style=\"white-space: pre-wrap; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: rgb(0, 0, 0);\">We&#39;d like to know how you would (hypothetically) trade off additional payments from this study vs. receiving drink containers with the label.<br \/>\nPlease choose the option you prefer in <\/span><strong style=\"white-space: pre-wrap; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: rgb(0, 0, 0);\">each row<\/strong><span style=\"white-space: pre-wrap; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: rgb