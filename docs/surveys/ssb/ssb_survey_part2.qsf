]\").removeClass(\"letters_selected\").addClass(\"letters\");\n\t$j(this ).removeClass(\"letters\").addClass(\"letters_selected\");\t\n            Qualtrics.SurveyEngine.setEmbeddedData(prefix+\"IdFinal_sprite_hyp\", id_number);\n\t\t\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"ChoiceFinal_sprite_hyp\", choice_now);\n\tif (choice_now.indexOf(\"left\") >= 0) { \n\t\t\t\tvar norm_lb = (id_number-1)*increment;\n\t\t\t\tvar norm_ub = (id_number)*increment;\n\t\t\t} else {\t\n\t \t\t\tvar norm_lb = (id_number-2)*increment; \n\t \t\t\tvar norm_ub = (id_number-1)*increment; \n\t \t\t};   \n\tif (choice_now==\"21left\") { \n\t\tvar norm_lb = stake;\n\t\tvar norm_ub = stake;\n\t\tvar changed_now =1; \n\t\tchanged.push(changed_now);\n\t};\n\tif (choice_now==\"1right\") { \n\t\tvar norm_lb = 0;\n\t\tvar norm_ub = 0;\n\t\tvar changed_now =2; \n\t\tchanged.push(changed_now);\n\t};\n\tif (norm_lb < increment) { \n\t\tvar norm_lb = 0;\n\t\tvar changed_now =3 ;\n\t\tchanged.push(changed_now);\n\t};\n\tif (norm_lb > stake) { \n\t\tvar norm_lb = stake;\n\t\tvar changed_now =4 ;\n\t\tchanged.push(changed_now);\n\t};\n\tif (norm_ub < increment) { \n\t\tvar norm_ub = 0;\n\t\tvar changed_now =5 ;\n\t\tchanged.push(changed_now);\n\t};\n\tif (norm_ub > stake) { \n\t\tvar norm_ub = stake;\n\t\tvar changed_now =6 ;\n\t\tchanged.push(changed_now);\n\t};\n\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"LB\", norm_lb);\n\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"UB\", norm_ub);\t\t\t\n\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"Changed\", changed);\t\t\t\n\t\tfor (k = id_number -1; k > 0; k--) {\t\n\t\t\tx = \"#\" + String(k) + \"left\";\n\t\t\ty = \"#\" + String(k) + \"right\";\n\t\t\t$j( x ).removeClass(\"letters\").addClass(\"letters_selected\");\n\t\t\t$j( y ).addClass(\"letters\").removeClass(\"letters_selected\");\n\t\t}\n\t\tfor (k = id_number +1; k < 101; k++) {\n\t\t\tx = \"#\" + String(k) + \"right\";\n\t\t\ty = \"#\" + String(k) + \"left\";\n\t\t\t$j(x).prop(\"checked\", true);\n\t\t\t$j( x ).removeClass(\"letters\").addClass(\"letters_selected\");\n\t\t\t$j( y ).addClass(\"letters\").removeClass(\"letters_selected\");\n\t\t}\n});\n\n$j('table.uncertainty').floatThead({\n\tuseAbsolutePositioning: false\n\t\/\/ absolutePositioning is better for\n\t\/\/ highly dynamic sites\n\t\/\/ (which this is not)\n});\n\n\t\/\/ enable submit button when variable no longer -1 \n\t this.questionclick = function(event,element)\n    { \t\t \n\tif (choice_now != -1 ) {this.enableNextButton(); }\n     else   { this.disableNextButton();  }\n\t}\n\t\n});","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"<div style=\"text-align: left;\"><span style=\"white-space: pre-wrap; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: rgb(0, 0, 0);\">We&#39;d like to know how you would (hypothetically) trade off additional payments from this study vs. receiving drink containers with the label.<br \/>\nPlease choose the option you prefer in <\/span><strong style=\"white-space: pre-wrap; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: rgb(0, 0, 0);\">each row<\/strong><span style=\"white-space: pre-wrap; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: rgb(0, 0, 0);\">:<\/span><\/div>","DisplayLogic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID829\/SelectableChoice\/4","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">\n\n&amp;nbsp;\nImagine that drink manufacturers could print the above label on some drink containers. Also imagine that the computer selects you to receive the 12 pack of Sprite. Would you prefer to rece...<\/span> <span class=\"LeftOpDesc\">With the label<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID829\/SelectableChoice\/4","LogicType":"Question","Operator":"Selected","QuestionID":"QID829","QuestionIDFromLocator":"QID829","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":