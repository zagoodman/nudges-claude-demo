lemonade_practice\", times);\n      \t\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"Choices_lemonade_practice\", choices);\n\t\n\tvar id_number = parseInt(id, 10);\n\t$j(\"td[name='\"+id+\"']\").removeClass(\"letters_selected\").addClass(\"letters\");\n\t$j(this ).removeClass(\"letters\").addClass(\"letters_selected\");\t\n            Qualtrics.SurveyEngine.setEmbeddedData(prefix+\"IdFinal_lemonade_practice\", id_number);\n\t\t\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"ChoiceFinal_lemonade_practice\", choice_now);\n\tif (choice_now.indexOf(\"left\") >= 0) { \n\t\t\t\tvar norm_lb = (id_number-1)*increment;\n\t\t\t\tvar norm_ub = (id_number)*increment;\n\t\t\t} else {\t\n\t \t\t\tvar norm_lb = (id_number-2)*increment; \n\t \t\t\tvar norm_ub = (id_number-1)*increment; \n\t \t\t};   \n\tif (choice_now==\"21left\") { \n\t\tvar norm_lb = stake;\n\t\tvar norm_ub = stake;\n\t\tvar changed_now =1; \n\t\tchanged.push(changed_now);\n\t};\n\tif (choice_now==\"1right\") { \n\t\tvar norm_lb = 0;\n\t\tvar norm_ub = 0;\n\t\tvar changed_now =2; \n\t\tchanged.push(changed_now);\n\t};\n\tif (norm_lb < increment) { \n\t\tvar norm_lb = 0;\n\t\tvar changed_now =3 ;\n\t\tchanged.push(changed_now);\n\t};\n\tif (norm_lb > stake) { \n\t\tvar norm_lb = stake;\n\t\tvar changed_now =4 ;\n\t\tchanged.push(changed_now);\n\t};\n\tif (norm_ub < increment) { \n\t\tvar norm_ub = 0;\n\t\tvar changed_now =5 ;\n\t\tchanged.push(changed_now);\n\t};\n\tif (norm_ub > stake) { \n\t\tvar norm_ub = stake;\n\t\tvar changed_now =6 ;\n\t\tchanged.push(changed_now);\n\t};\n\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"LB\", norm_lb);\n\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"UB\", norm_ub);\t\t\t\n\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"Changed\", changed);\t\t\t\n\t\tfor (k = id_number -1; k > 0; k--) {\t\n\t\t\tx = \"#\" + String(k) + \"left\";\n\t\t\ty = \"#\" + String(k) + \"right\";\n\t\t\t$j( x ).removeClass(\"letters\").addClass(\"letters_selected\");\n\t\t\t$j( y ).addClass(\"letters\").removeClass(\"letters_selected\");\n\t\t}\n\t\tfor (k = id_number +1; k < 101; k++) {\n\t\t\tx = \"#\" + String(k) + \"right\";\n\t\t\ty = \"#\" + String(k) + \"left\";\n\t\t\t$j(x).prop(\"checked\", true);\n\t\t\t$j( x ).removeClass(\"letters\").addClass(\"letters_selected\");\n\t\t\t$j( y ).addClass(\"letters\").removeClass(\"letters_selected\");\n\t\t}\n});\n\n$j('table.uncertainty').floatThead({\n\tuseAbsolutePositioning: false\n\t\/\/ absolutePositioning is better for\n\t\/\/ highly dynamic sites\n\t\/\/ (which this is not)\n});\n\n\t\/\/ enable submit button when variable no longer -1 \n\t this.questionclick = function(event,element)\n    { \t\t \n\tif (choice_now != -1 ) {this.enableNextButton(); }\n     else   { this.disableNextButton();  }\n\t}\n\t\n});"}},{"SurveyID":"SV_9Xle3s32xKQvH2C","Element":"QO","PrimaryAttribute":"QO_WiCMxJc6AQQvdd9","SecondaryAttribute":"New Quota","TertiaryAttribute":null,"Payload":{"Name":"New Quota","Occurrences":3000,"Logic":{"0":{"0":{"LogicType":"EmbeddedField","LeftOperand":"Part2AttentionCheckFailed","Operator":"EqualTo","RightOperand":"0","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span>  <span class=\"LeftOpDesc\">Part2AttentionCheckFailed<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 0 <\/span>"},"1":{"LogicType":"EmbeddedField","LeftOperand":"Part2AllQuestionsAnswered","Operator":"EqualTo","RightOperand":"1","Type":"Expression","Description":"<span class=\"ConjDesc\">And<\/span>  <span class=\"LeftOpDesc\">Part2AllQuestionsAnswered<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>","Conjuction":"And"},"Type":"If"},"Type":"BooleanExpression"},"LogicType":"Simple","QuotaAction":"EndCurrentSurvey","OverQuotaAction":null,"ActionInfo":{"0":{"0":{"ActionType":"EndCurrentSurvey","Type":"Expression","LogicType":"QuotaAction"},"Type":"If"},"Type":"BooleanExpression"},"ID":"QO_WiCMxJc6AQQvdd9","QuotaRealm":"Survey","QuotaSchedule":null,"EndSurveyOptions":{"EndingType":"Default","ResponseFlag":"QuotaMet","SurveyTermination":"DefaultMessage"}}},{"SurveyID":"SV_9Xle3s32xKQvH2C","Element":"SQ","PrimaryAttribute":"QID756","SecondaryAttribute":"Now we'd like to learn how you'd choose between pairs of drinks with similar flavors at different...","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:16px;\"><span style=\"font-family:Arial,Helvetica,sans-serif;\">Now we&#39;d like to learn how you&#39;d choose between pairs of drinks with similar flavors at different price levels. In the next few screens, we&#39;ll give you a bunch of choices between two drinks at different prices.&nbsp;<\/span><\/span>\n<div>&nbsp;<\/div>\n\n<div><span style=\"font-size: 16px;\"><b>Think carefully<\/b>, because the computer may randomly select one of the following questions and give you what you chose in that question. Click <a href=\"https:\/\/drive.google.com\/file\/d\/1POP-hWZVvsxNdSA8Z5y1M9CBiDwlnKZv\/view?usp=sharing\" target=\"_blank\">here<\/a> if you want more information on how the computer randomly selects questions.<\/span><\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Now we'd like to learn how you'd choose between pairs of drinks with similar flavors at different...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DataVisibility":{"Private":false,"Hidden":false},"QuestionJS":false,"QuestionText_Unsafe":"<span style=\"font-size:16px;\"><span style=\"font-family:Arial,Helvetica,sans-serif;\">In the next few screens, we&#39;ll show you pairs of drinks with similar flavors. We&#39;d like to learn how you would choose between these drinks at different prices.<br \/>\n<br \/>\nHere&#39;s how it works. The table below has 13 rows. In&nbsp;<strong>each row<\/strong>, we&#39;d like you to select whether you prefer one of the three drinks you previously selected as your favorites versus an alternative drink. Suppose, for example, that you chose the Minute Maid Lemonade as one of your three drinks and you are shown the Coca-Cola as the alternative drink.&nbsp;<\/span><\/span>\n<ul>\n\t<li><span style=\"font-size:16px;\"><span style=\"font-family:Arial,Helvetica,sans-serif;\">The Minute Maid Lemonade costs a different amount in each row, ranging from $1 to $7.<\/span><\/span><\/li>\n\t<li><span style=\"font-size:16px;\"><span style=\"font-family:Arial,Helvetica,sans-serif;\">The Coca-Cola&nbsp;costs the same in each row: $4.<\/span><\/span><\/li>\n<\/ul>\n<span style=\"font-size:16px;\"><span style=\"font-family:Arial,Helvetica,sans-serif;\">The price of the Minute Maid Lemonade is relatively low at the top and relatively high at the bottom. Thus, many (although not all) people will choose the Minute Maid Lemonade at the top and the Coca-Cola at the bottom. The main thing to decide is where you want to switch from the Minute Maid Lemonade to the Coca-Cola.<br \/>\n<br \/>\nTo help you answer quickly, we programmed the computer to select on the left for all rows above where you click, and on the right for all rows below. So you just need to decide where you want to switch from left to right, and click there. You can click as many times as you want; then click &ldquo;Next&rdquo; when you are happy with your final choices.<br \/>\n<br \/>\nPlease make your choices in the table below. This one is just for practice.<\/span><\/span>","DataExportTag":"pre_intro","QuestionID":"QID756"}},{"SurveyID":"SV_9Xle3s32xKQvH2C","Element":"SQ","PrimaryAttribute":"QID438","SecondaryAttribute":"Now we\u2019d like to know how satisfied you would be with receiving each of the following drinks, whe.","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:19px;\"><span id=\"docs-internal-guid-7f159f4b-7fff-9e82-9122-ce933600aa45\"><span style=\"font-family: Arial; color: 