Engine.addOnPageSubmit(function()\n{\n\tvar selectedRecode = this.getChoiceRecodeValue(this.getSelectedChoices());\n\tif (selectedRecode == 1) {  \/\/ selected dynamic value on the left\n\t\tvar sign = 1;\n\t} else {  \/\/ selected fixed 2000 value on the right\n\t\tvar sign = -1;\n\t}\n\tvar left_drink = 4;\n\t\n\t\/\/ save out what the next page's left drink value should be (display with 2 places after the decimal)\n\tvar next_left_drink_value = left_drink + sign * (1.60 * Math.pow(0.5, (0)));\n\tQualtrics.SurveyEngine.setEmbeddedData('next_left_drink_value', next_left_drink_value.toFixed(2));\n\t\n});","DefaultChoices":false,"GradingData":[],"DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_9Xle3s32xKQvH2C","Element":"SQ","PrimaryAttribute":"QID851","SecondaryAttribute":"Please click on the choice you would prefer given the prices per 12-pack below.","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:16px;\"><span style=\"font-family:Arial,Helvetica,sans-serif;\">Please click on the choice you would prefer given the prices per 12-pack below.<\/span><\/span>","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Please click on the choice you would prefer given the prices per 12-pack below.","Choices":{"1":{"Display":"Minute Maid Lemonade for $${e:\/\/Field\/next_left_drink_value}"},"2":{"Display":"LaCroix Lemon for $4.00"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnPageSubmit(function()\n{\n\tvar selectedRecode = this.getChoiceRecodeValue(this.getSelectedChoices());\n\tif (selectedRecode == 1) {  \/\/ selected dynamic value on the left\n\t\tvar sign = 1;\n\t} else {  \/\/ selected fixed 2000 value on the right\n\t\tvar sign = -1;\n\t}\n\t\n\tvar current_loop_num = parseInt(\"${lm:\/\/CurrentLoopNumber}\");\n\t\n\t\/\/ currently displayed left drink value is the \"next\" value we saved out from last round\n\tvar curr_left_drink_value = Number(parseFloat(\"${e:\/\/Field\/next_left_drink_value}\").toFixed(2));\n\t\n\t\/\/ save out what the next page's left drink value should be (display it with 2 places after the decimal)\n\tvar next_left_drink_value = curr_left_drink_value + sign * (1.60 * Math.pow(0.5, (current_loop_num)))\n\tQualtrics.SurveyEngine.setEmbeddedData('next_left_drink_value', next_left_drink_value.toFixed(2));\n\t\n\t\/\/ save out WTP value if this is the 4th row\n\tif (current_loop_num == 3) {\n\t\tif (selectedRecode == 1) {  \/\/ selected left on 4th screen\n\t\t\tQualtrics.SurveyEngine.setEmbeddedData('wtp_lemonade_b', curr_left_drink_value + 0.2 - 4);\n\t\t} else {  \/\/ selected right on 4th screen\n\t\t\tQualtrics.SurveyEngine.setEmbeddedData('wtp_lemonade_b', curr_left_drink_value - 0.2 - 4);\n\t\t}\n\t}\n});","DefaultChoices":false,"GradingData":[],"QuestionText_Unsafe":"<span style=\"font-size:16px;\"><span style=\"font-family:Arial,Helvetica,sans-serif;\">Please click on the choice you would prefer given the prices per 12-pack below.<\/span><\/span>","DataExportTag":"Q851","QuestionID":"QID851","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_9Xle3s32xKQvH2C","Element":"SQ","PrimaryAttribute":"QID852","SecondaryAttribute":"Please click on the choice you would prefer given the prices per 12-pack below.","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-family: Arial, Helvetica, sans-serif; font-size: 16px;\">Please click on the choice you would prefer given the prices per 12-pack below.<\/span>","DefaultChoices":false,"DataExportTag":"Q269","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Please click on the choice you would prefer given the prices per