w==\"1right\") { \n\t\tvar norm_lb = 0;\n\t\tvar norm_ub = 0;\n\t\tvar changed_now =2; \n\t\tchanged.push(changed_now);\n\t};\n\tif (norm_lb < increment) { \n\t\tvar norm_lb = 0;\n\t\tvar changed_now =3 ;\n\t\tchanged.push(changed_now);\n\t};\n\tif (norm_lb > stake) { \n\t\tvar norm_lb = stake;\n\t\tvar changed_now =4 ;\n\t\tchanged.push(changed_now);\n\t};\n\tif (norm_ub < increment) { \n\t\tvar norm_ub = 0;\n\t\tvar changed_now =5 ;\n\t\tchanged.push(changed_now);\n\t};\n\tif (norm_ub > stake) { \n\t\tvar norm_ub = stake;\n\t\tvar changed_now =6 ;\n\t\tchanged.push(changed_now);\n\t};\n\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"LB\", norm_lb);\n\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"UB\", norm_ub);\t\t\t\n\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"Changed\", changed);\t\t\t\n\t\tfor (k = id_number -1; k > 0; k--) {\t\n\t\t\tx = \"#\" + String(k) + \"left\";\n\t\t\ty = \"#\" + String(k) + \"right\";\n\t\t\t$j( x ).removeClass(\"letters\").addClass(\"letters_selected\");\n\t\t\t$j( y ).addClass(\"letters\").removeClass(\"letters_selected\");\n\t\t}\n\t\tfor (k = id_number +1; k < 101; k++) {\n\t\t\tx = \"#\" + String(k) + \"right\";\n\t\t\ty = \"#\" + String(k) + \"left\";\n\t\t\t$j(x).prop(\"checked\", true);\n\t\t\t$j( x ).removeClass(\"letters\").addClass(\"letters_selected\");\n\t\t\t$j( y ).addClass(\"letters\").removeClass(\"letters_selected\");\n\t\t}\n});\n\n$j('table.uncertainty').floatThead({\n\tuseAbsolutePositioning: false\n\t\/\/ absolutePositioning is better for\n\t\/\/ highly dynamic sites\n\t\/\/ (which this is not)\n});\n\n\t\/\/ enable submit button when variable no longer -1 \n\t this.questionclick = function(event,element)\n    { \t\t \n\tif (choice_now != -1 ) {this.enableNextButton(); }\n     else   { this.disableNextButton();  }\n\t}\n\t\n});","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"<div style=\"text-align: left;\"><span style=\"white-space: pre-wrap; font-family: Arial, Helvetica, sans