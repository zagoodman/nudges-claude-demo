/li>\n\t\t\t\t<li>MPG: 23&nbsp;(combined city\/highway)<\/li>\n\t\t\t\t<li>Engine: 2.0&nbsp;L 4-cylinder<\/li>\n\t\t\t\t<li>Transmission: Automatic<\/li>\n\t\t\t\t<li>Total seats: 5<\/li>\n\t\t\t<\/ul>\n\t\t\tPlease click <a href=\"https:\/\/www.ford.com\/cars\/fusion\/\" target=\"_blank\">here<\/a> for more information.&nbsp;<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>","QuestionJS":"\/\/Example Code \n\nQualtrics.SurveyEngine.addOnload(function() {\n\n\/\/ disable submit button\n\t this.disableNextButton();\n\n\tvar loop = parseInt(\"${lm:\/\/CurrentLoopNumber}\");\n\t\/\/$j(\".QuestionText\").remove();\n\tvar inputId = \"#\" + String(this.questionId);\n\n\/\/ Using Piped Text to get embedded data fields\n\tvar stake = parseInt(\"${e:\/\/Field\/stake}\");\n\tvar optionA = \"2000\"\n\tvar optionAunits = \"$\";\n\tvar optionBunits = \"$\";\n\tvar prefix = \"xnorm\";\n\/\/ ============================================================================\n\/\/ TABLE COLUMN HEADERS \n\t$j(inputId).append(\"<table  align='center' class='uncertainty'>\\\n<thead class='uncertaintyhead'>\\\n<tr>\\\n\t<th style='width:12em' class='thtext'> Yearly Lease Payment for the Charger  <\/th>\\\n\t<th style='width:1em'><\/th>\\\n\t<th style='width:12em' class='thtext'> Yearly Lease Payment for the Fusion   <\/th>\\\n<\/tr>\\\n<\/thead>\\\n<tbody class='uncert' id='maintable'>\\\n<tr class='middletd'>\\\n\t<td><\/td>\\\n\t<td><\/td>\\\n\t<td><\/td>\\\n<\/tr>\\\n<\/tbody>\\\n<\/table>\")\n\/\/ ============================================================================\n\/\/ TABLE ROWS \nmultistring = \"\";\nincrement = 100;\nfor (i = 5; i <= (stake+500)\/increment; i++) {\n\tvar num = i*increment;\n\tvar n = num.toFixed(0);\n\tmultistring = multistring + \"\\\n<tr class='middletd'> <td style='width:10em;border-top: 1px solid black;border-bottom: 1px solid black' class='letters' id='\" + (i+1) + \"left' name='\" + (i+1) + \"'>\" +optionBunits + n + \" \" + \"<\/td> <td style='width:10em'>OR<\/td> <td style='width:10em;border-top: 1px solid black;border-bottom: 1px solid black'  class='letters' id='\" + (i+1) + \"right' name='\" + (i+1) + \"'>\" + optionAunits + optionA + \" \" +\"<\/td> <\/tr>\";\n}\n\/\/ ============================================================================\n\/\/ SAVE OUTPUT \n\n$j('#maintable').append(multistring)\n\t\t\t\n\nvar choiceThatCounts = -1;\n\/\/save the data\n    var time_start = Date.now() \/ 1000;\n    var times = [];\n    var choices = [];\n    var changed=[];\n\/\/ Up the list count\n\tvar list = \"${e:\/\/Field\/list}\"\n\tvar list =\tparseInt(list);\n\tvar list = list + 1;\n\tQualtrics.SurveyEngine.setEmbeddedData(\"list\", list);\n\t\n\/\/ set var = -1 \nvar choice_now = -1 ; \n\n$j('.letters').click(function() {\n\tid = $j(this).attr('name');\n\tvar time = Date.now() \/ 1000 - time_start;      \n    choice_now = $j(this).attr('id');\n    times.push(time.toFixed(2));\n    choices.push(choice_now);\n       \t\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"Time_dodge_practice\", times);\n      \t\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"Choices_dodge_practice\", choices);\n\t\n\tvar id_number = parseInt(id, 10);\n\t$j(\"td[name='\"+id+\"']\").removeClass(\"letters_selected\").addClass(\"letters\");\n\t$j(this ).removeClass(\"letters\").addClass(\"letters_selected\");\t\n            Qualtrics.SurveyEngine.setEmbeddedData(prefix+\"IdFinal_dodge_practice\", id_number);\n\t\t\tQualtrics.SurveyEngine.setEmbeddedData(prefix+\"ChoiceFinal_dodge_practice\", choice_now);\n\tif (choice_now.indexOf(\"left\") >= 0) { \n\t\t\t\tvar norm_lb = (id_number-1)*increment;\n\t\t\t\tvar norm_ub = (id_number)*increment;\n\t\t\t} else {\t\n\t \t\t\tvar norm_lb = (id_number-2)*increment; \n\t \t\t\tvar norm_ub = (id_number-1)*increment; \n\t \t\t};   \n\tif (choice_now==\"21left\") { \n\t\tvar norm_lb = stake;\n\t\tvar norm_ub = stake;\n\t\tvar changed_now =1; \n\t\tchanged.push(changed_now);\n\t};\n\tif (choice_now==\"1righ