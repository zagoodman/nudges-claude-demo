ce: pre-wrap;\">(For reference, the average new car is driven about 13,500 miles per year.)<\/span><\/span><\/span><\/span><\/p>","DefaultChoices":false,"QuestionType":"TE","Selector":"SL","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Think about your \"primary car\": the car you own that you personally drive the most. How much do y...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"ContentType","ContentType":"ValidNumber","ValidDateType":"DateWithFormat","ValidPhoneType":"ValidUSPhone","ValidZipType":"ValidUSZip"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place Your Javascript Below This Line*\/\n\t\njQuery(\"#\"+this.questionId+\" .InputText\").css(\"width\", \"150px\"); \n\t\nvar inputs = $(this.getQuestionContainer()).select('input[type=\"text\"]');\n\nfor (var i = 0; i < inputs.length; i++) {\n  var input = inputs[i];\n  $(input).insert({after: ' miles in 2019'});\n}\n});\n\nQualtrics.SurveyEngine.addOnPageSubmit(function()\n{\n\tvar miles_driven_2019 = document.getElementById('QR~' + this.questionId).value;\n\tmiles_driven_2019 = parseFloat(miles_driven_2019.replace(\/,\/g, ''));\n\tQualtrics.SurveyEngine.setEmbeddedData('miles_driven_2019', miles_driven_2019);\n});","QuestionText_Unsafe":"<span id=\"docs-internal-guid-3ff5a021-7fff-390d-4b87-82a2cafedb62\"><span style=\"font-size: 11pt; font-family: Arial; color: rgb(0, 0, 0); background-color: transparent; font-variant-numeric: normal; font-variant-east-asian: normal; vertical-align: baseline; white-space: pre-wrap;\">If you were leasing a new car, how many miles would you expect to drive it <\/span><span style=\"font-size: 11pt; font-family: Arial; color: rgb(0, 0, 0); background-color: transparent; font-weight: 700; font-variant-numeric: normal; font-variant-east-asian: normal; vertical-align: baseline; white-space: pre-wrap;\">per year<\/span><span style=\"font-size: 11pt; font-family: Arial; color: rgb(0, 0, 0); background-color: transparent; font-variant-numeric: normal; font-variant-east-asian: normal; vertical-align: baseline; white-space: pre-wrap;\"> in each of the next 3 years? (For reference, the average new car is driven about 13,500 miles per year.)<\/span><\/span>","DataExportTag":"miles_per_year","QuestionID":"QID388","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_bmebs5HpMXjiq3A","Element":"SQ","PrimaryAttribute":"QID383","SecondaryAttribute":"To what extent do you pay attention to the following features when choosing between cars? (Please...","TertiaryAttribute":null,"Payload":{"QuestionText":"To what extent do you pay attention to the following features when choosing between cars? (Please rate from 0 (no attention) to 10 (full attention).)","DefaultChoices":false,"DataExportTag":"bias_proxies","QuestionID":"QID383","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"To what extent do you pay attention to the following features when choosing between cars? (Please...","Choices":{"1":{"Display":"Price"},"2":{"Display":"Color"},"4":{"Display":"Fuel economy"},"5":{"Display":"Horsepower"}},"ChoiceOrder":[1,2,"4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":13,"Labels":[]}},{"SurveyID":"SV_bmebs5HpMXjiq3A","Element":"SQ","PrimaryAttribute":"QID627","SecondaryAttribute":"We have one final question: Imagine that you or someone else in your household gets a raise such...","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"color:#000000;\"><span style=\"font-family:Arial,Helvetica,sans-serif;\"><span style=\"font-size:16px;\">We have one final question:<br \/>\n<br \/>\nImagine that you or someone else in your household gets a raise such that over the next five years, your household&rsquo;s income is $1,000 higher each year than what you expected. How much of this would your household spend, and how much would your household save over each of the next five years? (For purposes of this question, consider paying off debt, such as reducing your mortgage, a form of saving.)&nbsp;<\/span><\/span><span style=\"font-size:16px;\"><span style=\"font-family:Arial,Helvetica,sans-serif;\">If no one in your household is going to be employed for most of the next five years, please write &ldquo;N\/A.&rdquo;<\/span><\/span><\/span>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\njQuery(\"#\"+this.questionId+\" .InputText\").css(\"width\", \"150px\");\n\t\nvar inputs = $(this.getQuestionContainer()).select('input[type=\"text\"]');\n\n$(inputs[0]).insert({before: 'Spend an extra $ '});\n$(inputs[1]).insert({before: 'Save an extra $ '});\n\nfor (var i = 0; i < inputs.length; i++) {\n  var input = inputs[i];\n  $(input).insert({after: ' per year'});\n}\n\n\/\/ set both spend\/save values to blanks initially\ninputs[0].value = '';\ninputs[1].value = '';\ninputs[1].disabled = true;\n\t\nEvent.observe(document, 'keyup', function computeSavings(e) {\n\tvar spend = parseFloat(inputs[0].value.replace(\/,\/g, ''));\n\tif (inputs[0].value.toLowerCase() == 'n\/a' | inputs[0].value.toLowerCase() == 'na' | inputs[0].value.toLowerCase() == '\\\"n\/a\\\"') {\n\t\tinputs[1].value = 'N\/A';\n\t} else if (spend.toString() == 'NaN') {\n\t\tinputs[1].value = '';\n\t} else {\n\t\tvar savings = 1000 - spend;\n\t\tinputs[1].value = savings;\n\t}\n\t\n});\n\t\n\t\n\n\t\n\t\n\t\n\t\/\/ compute net annual value of both cars based on the selection in each of the 4 MPL tables (8 total \"switch\" points)\n\t\/\/ 8 variables are: \n\t\t\/\/ Nissan: nissan_net_b_js nissan_net_e_js\n\t\t\/\/ Ford\/\"Dodge\" (baseline): dodge_net_js dodgeh_net_js\n\t\t\/\/ Honda\/Subaru: honda_net_b_js honda_net_e_js\n\t\t\/\/ Ford (endline): ford_net_js fordh_net_js\n\t\n\t\/\/ pipe in embedded fields\n\t\t\/\/ Baseline\n\tvar nissan_lease_wtp_b = parseInt(\"${e:\/\/Field\/nissan_lease_wtp_b}\");\n\tvar dodge_lease_wtp_b_nissan = parseInt(\"${e:\/\/Field\/dodge_lease_wtp_b_nissan}\");\n\tvar honda_lease_wtp_b = parseInt(\"${e:\/\/Field\/honda_lease_wtp_b}\");\n\tvar dodge_lease_wtp_b_honda = parseInt(\"${e:\/\/Field\/dodge_lease_wtp_b_honda}\");\n\t\t\/\/ Endline\n\tvar nissan_lease_wtp_e = parseInt(\"${e:\/\/Field\/nissan_lease_wtp_e}\");\n\tvar ford_lease_wtp_e_nissan = parseInt(\"${e:\/\/Field\/ford_lease_wtp_e_nissan}\");\n\tvar honda_lease_wtp_e = parseInt(\"${e:\/\/Field\/honda_lease_wtp_e}\");\n\tvar ford_lease_wtp_e_honda = parseInt(\"${e:\/\/Field\/ford_lease_wtp_e_honda}\");\n\n\t\/\/ censored row was selected\n\n\t\/\/ Nissan base\n\tif (nissan_lease_wtp_b == 450) { \/\/ always right\n\t\tnissan_lease_wtp_b = 500;\n\t}\n\tif (nissan_lease_wtp_b == 3550) { \/\/ always left\n\t\tnissan_lease_wtp_b = 3500;\n\t}\n\t\n\t\/\/ Nissan end\n\tif (nissan_lease_wtp_e == 450) { \/\/ always right\n\t\tnissan_lease_wtp_e = 500;\n\t}\n\tif (nissan_lease_wtp_e == 3550) { \/\/ always left\n\t\tnissan_lease_wtp_e = 3500;\n\t}\n\t\n\t\/\/ Honda base\n\tif (honda_lease_wtp_b == 450) { \/\/ always right\n\t\thonda_lease_wtp_b = 500;\n\t}\n\tif (honda_lease_wtp_b == 3550) { \/\/ always left\n\t\thonda_lease_wtp_b = 3500;\n\t}\n\t\n\t\/\/ Honda end\n\tif (honda_lease_wtp_e == 450) { \/\/ always right\n\t\thonda_lease_wtp_e = 500;\n\t}\n\tif (honda_lease_wtp_e == 3550) { \/\/ always left\n\t\thonda_lease_wtp_e = 3500;\n\t}\n\t\n\t\/\/ Dodge base Nissan\n\tif (dodge_lease_wtp_b_nissan == 450) { \/\/ always right\n\t\tdodge_lease_wtp_b_nissan = 500;\n\t}\n\tif (dodge_lease_wtp_b_nissan == 3550) { \/\/ always left\n\t\tdodge_lease_wtp_b_nissan = 3500;\n\t}\n\t\n\t\/\/ Dodge base Honda\n\tif (dodge_lease_wtp_b_honda == 450) { \/\/ always right\n\t\tdodge_lease_wtp_b_honda = 500;\n\t}\n\tif (dodge_lease_wtp_b_honda == 3550) { \/\/ always left\n\t\tdodge_lease_wtp_b_honda = 3500;\n\t}\n\t\n\t\/\/ Ford end Nissan\n\tif (ford_lease_wtp_e_nissan == 450) { \/\/ always right\n\t\tford_lease_wtp_e_nissan = 500;\n\t}\n\tif (ford_lease_wtp_e_nissan == 3550) { \/\/ always left\n\t\tford_lease_wtp_e_nissan = 3500;\n\t}\n\t\n\t\/\/ Ford end Honda\n\tif (ford_lease_wtp_e_honda == 450) { \/\/ always right\n\t\tford_lease_wtp_e_honda = 500;\n\t}\n\tif (ford_lease_wtp_e_honda == 3550) { \/\/ always left\n\t\tford_lease_wtp_e_honda = 3500;\n\t}\n\t\n\t\n\t\/\/ net annual value calculation\n\t\n\t\t\/\/ Nissan base\n\tvar nissan_net_b_js = \"${e:\/\/Field\/nissan_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_thirty}\" - nissan_lease_wtp_b;\n\tQualtrics.SurveyEngine.setEmbeddedData(\"nissan_net_b_js\", nissan_net_b_js);\n\t\t\/\/ Nissan end\n\tvar nissan_net_e_js = \"${e:\/\/Field\/nissan_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_thirty}\" - nissan_lease_wtp_e;\n\tQualtrics.SurveyEngine.setEmbeddedData(\"nissan_net_e_js\", nissan_net_e_js);\n\t\n\t\t\/\/ Honda base\n\tvar honda_net_b_js = \"${e:\/\/Field\/honda_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_thirty}\" - honda_lease_wtp_b;\n\tQualtrics.SurveyEngine.setEmbeddedData(\"honda_net_b_js\", honda_net_b_js);\n\t\t\/\/ Honda end\n\tvar honda_net_e_js = \"${e:\/\/Field\/honda_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_thirty}\" - honda_lease_wtp_e;\n\tQualtrics.SurveyEngine.setEmbeddedData(\"honda_net_e_js\", honda_net_e_js);\n\t\n\t\t\/\/ Dodge base Nissan\n\tvar dodge_net_js = \"${e:\/\/Field\/ford_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_twentythree}\" - dodge_lease_wtp_b_nissan;\n\tQualtrics.SurveyEngine.setEmbeddedData(\"dodge_net_js\", dodge_net_js);\n\t\t\/\/ Dodge base Honda\n\tvar dodgeh_net_js = \"${e:\/\/Field\/ford_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_twentythree}\" - dodge_lease_wtp_b_honda;\n\tQualtrics.SurveyEngine.setEmbeddedData(\"dodgeh_net_js\", dodgeh_net_js);\n\t\n\t\t\/\/ Ford end Nissan\n\tvar ford_net_js = \"${e:\/\/Field\/ford_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_twentythree}\" - ford_lease_wtp_e_nissan;\n\tQualtrics.SurveyEngine.setEmbeddedData(\"ford_net_js\", ford_net_js);\n\t\t\/\/ Ford end Honda\n\tvar fordh_net_js = \"${e:\/\/Field\/ford_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_twentythree}\" - ford_lease_wtp_e_honda;\n\tQualtrics.SurveyEngine.setEmbeddedData(\"fordh_net_js\", fordh_net_js);\n\n\t\n\t\/\/ rescale each of the 8 net value \"switching\" points and MPL table endpoints into dollar value from $1 to $10\n\t\n\t\t\/\/ net value of endpoint at the top of the table for each of the 4 MPLs\n\tvar endpoint_top1;\n\tvar endpoint_top2;\n\tvar endpoint_top3;\n\tvar endpoint_top4;\n\t\t\/\/ net value of endpoint at the bottom of the table for each of the 4 MPLs\n\tvar endpoint_bottom1;\n\tvar endpoint_bottom2;\n\tvar endpoint_bottom3;\n\tvar endpoint_bottom4;\n\t\n\t\t\/\/ get \"left car\" variables stored\n\tvar left_car_nissan_base = \"${e:\/\/Field\/left_car_nissan_base}\";\n\tvar left_car_honda_base = \"${e:\/\/Field\/left_car_honda_base}\";\n\tvar left_car_nissan_end = \"${e:\/\/Field\/left_car_nissan_end}\";\n\tvar left_car_honda_end = \"${e:\/\/Field\/left_car_honda_end}\";\n\n\t\/\/ Baseline: Nissan vs. \"Dodge\"\n\tif (left_car_nissan_base == \"nissan\") {\n\t\tif (nissan_lease_wtp_b > 500) {  \/\/ 500 would have been \"highlighted\" in the table\n\t\t\tendpoint_top1 = \"${e:\/\/Field\/nissan_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_thirty}\" - 500;\n\t\t\t\t\/\/ bottom endpoint = \"switch\" point for car on the left\n\t\t\tendpoint_bottom1 = \"${e:\/\/Field\/nissan_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_thirty}\" - nissan_lease_wtp_b;\n\t\t} else {  \/\/ participant always selected right (\"Dodge\")\n\t\t\tendpoint_top1 = \"${e:\/\/Field\/ford_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_twentythree}\" - 2000;\n\t\t\tendpoint_bottom1 = \"${e:\/\/Field\/ford_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_twentythree}\" - 2000;\n\t\t}\n\t} else {  \/\/ left car was \"dodge\"\n\t\t\tif (dodge_lease_wtp_b_nissan > 500) {\n\t\t\t\tendpoint_top1 = \"${e:\/\/Field\/ford_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_twentythree}\" - 500;\n\t\t\t\t\t\/\/ bottom endpoint = \"switch\" point for car on the left\n\t\t\t\tendpoint_bottom1 = \"${e:\/\/Field\/ford_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_twentythree}\" - dodge_lease_wtp_b_nissan; \n\t\t\t} else {  \/\/ participant always selected right (Nissan)\n\t\t\t\tendpoint_top1 = \"${e:\/\/Field\/nissan_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_thirty}\" - 2000;\n\t\t\t\tendpoint_bottom1 = \"${e:\/\/Field\/nissan_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_thirty}\" - 2000;\n\t\t\t}\n\t}\n\t\n\t\/\/ Baseline: Honda\/Subaru vs. \"Dodge\"\n\t\t\/\/ get is_sh variable\n\tvar is_sh = parseInt(\"${e:\/\/Field\/is_sh}\");\n\tif (left_car_honda_base == \"honda\") {\n\t\tif (honda_lease_wtp_b > 500) {\n\t\t\t\/\/ honda or subaru\n\t\t\tif (is_sh == 0) {  \/\/ seen order is Honda at base, Subaru at end (so this is Honda)\n\t\t\t\tendpoint_top2 = \"${e:\/\/Field\/honda_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_thirty}\" - 500;\n\t\t\t} else {\n\t\t\t\tendpoint_top2 = \"${e:\/\/Field\/subaru_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_thirty}\" - 500;\n\t\t\t}\n\t\t\t\t\/\/ bottom endpoint = \"switch\" point for car on the left\n\t\t\tendpoint_bottom2 = \"${e:\/\/Field\/honda_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_thirty}\" - honda_lease_wtp_b;\n\t\t} else {  \/\/ participant always selected right (\"Dodge\")\n\t\t\tendpoint_top2 = \"${e:\/\/Field\/ford_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_twentythree}\" - 2000;\n\t\t\tendpoint_bottom2 = \"${e:\/\/Field\/ford_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_twentythree}\" - 2000;\n\t\t}\n\t} else {  \/\/ left car was \"dodge\"\n\t\tif (dodge_lease_wtp_b_honda > 500) {\n\t\t\tendpoint_top2 = \"${e:\/\/Field\/ford_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_twentythree}\" - 500;\n\t\t\t\t\/\/ bottom endpoint = \"switch\" point for car on the left\n\t\t\tendpoint_bottom2 = \"${e:\/\/Field\/ford_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_twentythree}\" - dodge_lease_wtp_b_honda;\n\t\t} else {  \/\/ participant always selected right (Honda\/Subaru)\n\t\t\tif (is_sh == 0) {  \/\/ seen order is Honda at base, Subaru at end (so this is Honda)\n\t\t\t\tendpoint_top2 = \"${e:\/\/Field\/honda_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_thirty}\" - 2000;\n\t\t\t\tendpoint_bottom2 = \"${e:\/\/Field\/honda_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_thirty}\" - 2000;\n\t\t\t} else {  \/\/ always right (Subaru)\n\t\t\t\tendpoint_top2 = \"${e:\/\/Field\/subaru_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_thirty}\" - 2000;\n\t\t\t\tendpoint_bottom2 = \"${e:\/\/Field\/subaru_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_thirty}\" - 2000;\n\t\t\t}\n\t\t}\n\t}\n\t\n\t\/\/ Endline: Nissan vs. Ford\n\tif (left_car_nissan_end == \"nissan\") {\n\t\tif (nissan_lease_wtp_e > 500) {  \/\/ 500 would have been \"highlighted\" in the table\n\t\t\tendpoint_top3 = \"${e:\/\/Field\/nissan_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_thirty}\" - 500;\n\t\t\t\t\/\/ bottom endpoint = \"switch\" point for car on the left\n\t\t\tendpoint_bottom3 = \"${e:\/\/Field\/nissan_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_thirty}\" - nissan_lease_wtp_e;\n\t\t} else {  \/\/ always selected right (Ford)\n\t\t\tendpoint_top3 = \"${e:\/\/Field\/ford_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_twentythree}\" - 2000;\n\t\t\tendpoint_bottom3 = \"${e:\/\/Field\/ford_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_twentythree}\" - 2000;\n\t\t}\n\t} else {  \/\/ left car was ford\n\t\t\tif (ford_lease_wtp_e_nissan > 500) {\n\t\t\t\tendpoint_top3 = \"${e:\/\/Field\/ford_enjoy_js}\" - \"${e:\/\/Field\/gas_cost_twentythree}\" - 500;\n\t\t\t\t\t\/\/ bottom endpoint = \"switch\" point for car on the left\n\t\t\t\tendpoint_bottom3 = \"${e:\/\/Field